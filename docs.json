{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Blink",
  "colors": {
    "primary": "#0058F0",
    "light": "#317cff",
    "dark": "#0058F0"
  },
  "background": {
    "dark": "#000000",
    "color": {
      "dark": "#000000"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "pages": [
          "getting-started",
          "setup",
          "supported-countries",
          {
            "group": "Storefront",
            "icon": "store",
            "expanded": true,
            "pages": [
              "creating-a-store",
              "customization",
              "orders",
              "audience",
              "discounts",
              "bumps",
              "store-settings"
            ]
          },
          {
            "group": "Products",
            "pages": [
              "add-products",
              "share-product",
              "deleting-products",
              "products-sorting"
            ],
            "icon": "box",
            "expanded": true
          },
          {
            "group": "Checkouts",
            "pages": [
              "store-checkout",
              "custom-checkouts",
              "overlay-checkout"
            ],
            "icon": "shopping-cart",
            "expanded": true
          },
          {
            "group": "Email",
            "icon": "mail",
            "expanded": true,
            "pages": [
              "cart-recovery",
              "broadcasts",
              "email-plans",
              "email-settings"
            ]
          },
          {
            "group": "Affiliates",
            "icon": "users",
            "expanded": true,
            "pages": [
              "affiliate-setup",
              "affiliate-manage",
              "affiliate-payouts"
            ]
          },
          {
            "group": "Splits",
            "pages": [
              "splits-overview",
              "splits-create-a-split",
              "splits-received",
              "splits-invites"
            ]
          },
          "analytics",
          {
            "group": "Financials",
            "pages": [
              "merchant-of-records",
              "fees",
              "payouts"
            ],
            "icon": "badge-dollar-sign",
            "expanded": true
          }
        ]
      },
      {
        "tab": "API",
        "pages": [
          "api-reference/introduction",
          {
            "group": "Blink API",
            "openapi": "api-reference/blink-api.json"
          },
          {
            "group": "Shopper API",
            "openapi": "api-reference/shopper-api.json"
          },
          {
            "group": "Growth API",
            "openapi": "api-reference/growth-api.json"
          },
          {
            "group": "Webhooks & Events",
            "openapi": "api-reference/webhooks-api.json"
          }
        ],
        "icon": "code"
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Blink",
      "href": "https://blink.store"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/blinkdotstore"
    }
  },
  "appearance": {
    "strict": true,
    "default": "dark",
    "banner": "Welcome to Blink documentation"
  },
  "logo": "/images/blink_dark_mode_icon.svg",
  "favicon": "/images/blink_dark_mode_icon.svg",
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "openapi": [
    "api-reference/blink-api.json",
    "api-reference/shopper-api.json",
    "api-reference/growth-api.json",
    "api-reference/webhooks-api.json"
  ]
}
