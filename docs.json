{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Blink",
  "colors": {
    "primary": "#0058F0",
    "light": "#317cff",
    "dark": "#0058F0"
  },
  "background": {
    "dark": "#000000",
    "color": {
      "dark": "#000000"
    }
  },
  "logo": {
    "dark": "/images/blink-logo-dark.svg",
    "light": "/images/blink-logo-light.svg"
  },
  "favicon": {
    "light": "/images/blink-mail-product.png",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "pages": [
          "getting-started",
          "setup",
          "supported-countries",
          {
            "group": "Storefront",
            "icon": "store",
            "expanded": true,
            "pages": [
              "creating-a-store",
              "customization",
              "orders",
              "audience",
              "discounts",
              "bumps",
              "store-settings"
            ]
          },
          {
            "group": "Products",
            "pages": [
              "add-products",
              "deliverables",
              "share-product",
              "deleting-products",
              "products-sorting"
            ],
            "icon": "box",
            "expanded": true
          },
          {
            "group": "Checkouts",
            "pages": [
              "store-checkout",
              "custom-checkouts",
              "overlay-checkout"
            ],
            "icon": "shopping-cart",
            "expanded": true
          },
          {
            "group": "Email",
            "icon": "mail",
            "expanded": true,
            "pages": [
              "cart-recovery",
              "broadcasts",
              "email-plans",
              "email-settings"
            ]
          },
          {
            "group": "Affiliates",
            "icon": "users",
            "expanded": true,
            "pages": [
              "affiliate-setup",
              "affiliate-manage",
              "affiliate-payouts"
            ]
          },
          {
            "group": "Splits",
            "pages": [
              "splits-overview",
              "splits-create-a-split",
              "splits-received",
              "splits-invites"
            ]
          },
          "analytics",
          {
            "group": "Financials",
            "pages": [
              "merchant-of-records",
              "fees",
              "payouts"
            ],
            "icon": "badge-dollar-sign",
            "expanded": true
          }
        ],
        "icon": "file"
      },
      {
        "tab": "API",
        "pages": [
          "api-reference/introduction",
          "api-reference/test-mode",
          {
            "group": "Blink API",
            "pages": [
              "api-reference/embedded-checkout"
            ],
            "openapi": "api-reference/blink-api.json"
          },
          {
            "group": "Webhooks & Events",
            "pages": [
              "api-reference/webhook-events"
            ],
            "openapi": "api-reference/webhooks-api.json"
          }
        ],
        "icon": "code"
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Blink",
      "href": "https://blink.store"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "openapi": [
    "api-reference/blink-api.json",
    "api-reference/webhooks-api.json"
  ],
  "appearance": {
    "strict": true
  }
}
