{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Blink",
  "colors": {
    "primary": "#0058F0",
    "light": "#317cff",
    "dark": "#0058F0"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "pages": [
          "getting-started",
          "setup",
          "supported-countries",
          {
            "group": "Products",
            "pages": [
              "add-products",
              "share-product",
              "deleting-products"
            ]
          },
          {
            "group": "Storefront",
            "pages": [
              "creating-a-store",
              "customization",
              "orders",
              "audience",
              "discounts",
              "email",
              "bumps",
              "store-settings"
            ]
          },
          {
            "group": "Checkouts",
            "pages": [
              "store-checkout",
              "custom-checkouts",
              "overlay-checkout"
            ]
          },
          {
            "group": "Financials",
            "pages": [
              "merchant-of-records",
              "fees",
              "payouts"
            ]
          }
        ]
      },
      {
        "tab": "Support",
        "href": "https://blink.store/contact"
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "logo": "/images/blink_dark_mode_icon.svg",
  "favicon": "/images/blink_dark_mode_icon.svg",
  "fonts": {
    "family": "Inter"
  },
  "background": {
    "color": {
      "dark": "#000000"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "icons": {
    "library": "lucide"
  },
  "banner": {
    "dismissible": false
  }
}